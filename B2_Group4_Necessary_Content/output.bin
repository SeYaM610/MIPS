1110 0000 0110 1111 : addi $sp, $zero, 15
1110 0000 0110 0000 : addi $sp, $zero, 0
1110 0000 0111 0001 : addi $t0, $zero, 1
1110 0110 0110 0001 : addi $sp, $sp, 1
0110 0110 0111 0000 : sw   $t0, 0($sp)
1110 0000 0111 0010 : addi $t0, $zero, 2
1110 0110 0110 0001 : addi $sp, $sp, 1
0110 0110 0111 0000 : sw   $t0, 0($sp)
1110 0000 0111 0001 : addi $t0, $zero, 1
1110 0110 0110 0001 : addi $sp, $sp, 1
0110 0110 0111 0000 : sw   $t0, 0($sp)
1110 0000 0111 0010 : addi $t0, $zero, 2
1110 0110 0110 0001 : addi $sp, $sp, 1
0110 0110 0111 0000 : sw   $t0, 0($sp)
1110 0000 0001 0000 : addi $t1, $zero, 0
1110 0000 0010 0000 : addi $t2, $zero, 0
1110 0000 0100 0100 : addi $t4, $zero, 4
0001 0100 0010 0101 : beq $t2, $t4, end
0100 0110 0011 0000 : lw   $t3, 0($sp)
1110 0110 0110 1111 : addi $sp, $sp, -1
1111 0001 0011 0001 : add  $t1, $t1, $t3
1110 0010 0010 0001 : addi $t2, $t2, 1
1000 0001 0001 0000 : j loop
